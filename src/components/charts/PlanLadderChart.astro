---
// The Bokksu price ladder: monthly price by plan length. Single-series column
// chart, zero baseline, every cap direct-labeled (so no y-axis is needed).
// Static data as of July 2026. No props.
const PLOT = 150; // px height of the $0-$40 plot area
const barHeight = (price: number) => Math.round((price / 40) * PLOT);

const plans = [
	{ term: '1 mo', price: 39.99, label: '$39.99' },
	{ term: '3 mo', price: 35.99, label: '$35.99' },
	{ term: '6 mo', price: 33.99, label: '$33.99' },
	{ term: '12 mo', price: 32.99, label: '$32.99' },
];
---

<figure class="chart">
	<p class="chart-title">Bokksu monthly price by plan length</p>
	<p class="sr-only">
		Column chart of Bokksu's monthly price by plan length. 1-month plan: $39.99
		per month. 3-month plan: $35.99. 6-month plan: $33.99. 12-month plan: $32.99
		per month. The monthly price steps down as the plan gets longer.
	</p>
	<div class="cols" aria-hidden="true">
		{
			plans.map((p) => (
				<div class="cell">
					<span class="val">{p.label}</span>
					<span class="bar" style={`height:${barHeight(p.price)}px`} />
				</div>
			))
		}
		{plans.map((p) => <span class="term">{p.term}</span>)}
	</div>
	<figcaption>Monthly price by plan length, as of July 2026.</figcaption>
</figure>

<style>
	.chart {
		margin: 2.5em 0;
	}
	.chart-title {
		font-weight: 700;
		color: rgb(var(--black));
		margin: 0 0 0.75em;
	}
	.cols {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		max-width: 380px;
	}
	.cell {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-end;
		border-bottom: 1px solid rgba(var(--gray), 45%); /* shared baseline */
	}
	.val {
		font-size: 0.75em;
		color: rgb(var(--gray-dark));
		margin-bottom: 0.35em;
	}
	.bar {
		width: 24px;
		background: var(--accent);
		border-radius: 4px 4px 0 0; /* rounded cap, square at the baseline */
	}
	.term {
		text-align: center;
		padding-top: 0.4em;
		font-size: 0.75em;
		color: rgb(var(--gray));
	}
	figcaption {
		margin-top: 0.75em;
		font-size: 0.75em;
		color: rgb(var(--gray));
	}
</style>
