---
// Clickable deformed map of Japan for the /regional hub — v2 artwork.
// Original SVG (no stock assets; the operator's reference images are
// unlicensed stock previews and must never be published). Honshu is a single
// landmass path with one shared coastline stroke so the country reads as one
// silhouette; regions are fill overlays with thin internal borders. Signed off
// at 85/100 by the Gemini art-director review (2026-07-19).
// Active areas link to the region sections below (#hokkaido etc. — ids come
// from REGIONS in consts.ts); gray areas pop an Inaripo "still investigating"
// bubble. Active = warm pink fill + emoji + red label, inactive = greige fill
// + gray label, so the states never rely on color alone.
import Inaripo from './Inaripo.astro';
---

<figure class="jmap" aria-label="Map of Japan — pick a region">
	<svg viewBox="0 0 1020 900" role="group" aria-label="Deformed map of Japan. Pink regions link to their snack sections; gray regions are still under investigation.">
		<!-- ===== Honshu: one landmass (base) ===== -->
		<path class="land" d="M 832,312 L 846,284 L 868,299 L 879,281 L 906,306 L 916,420 L 908,520 L 921,562 L 913,602 L 928,634 L 896,650 L 876,634 L 858,656 L 821,650 L 770,672 L 708,676 L 660,662 L 632,684 L 598,712 L 560,700 L 548,672 L 524,664 L 506,636 L 436,646 L 352,648 L 286,638 L 254,616 L 264,586 L 332,566 L 422,560 L 509,585 L 560,568 L 610,560 L 654,558 L 662,554 C 658,530 664,510 674,502 C 682,496 690,508 690,520 C 690,532 692,542 696,548 L 724,540 L 756,532 L 790,540 L 772,470 L 786,394 L 806,338 Z"/>

		<!-- ===== soon regions on Honshu (hover + bubble) ===== -->
		<g class="soon" role="button" tabindex="0" data-name="Tohoku" aria-label="Tohoku — still under investigation">
			<path class="fill" d="M 832,312 L 846,284 L 868,299 L 879,281 L 906,306 L 916,420 L 908,520 L 790,540 L 772,470 L 786,394 L 806,338 Z"/>
			<text class="label" x="848" y="428">Tohoku</text>
		</g>
		<g class="soon" role="button" tabindex="0" data-name="Chubu" aria-label="Chubu — still under investigation">
			<path class="fill" d="M 790,540 L 776,566 L 781,634 L 821,650 L 770,672 L 708,676 L 660,662 L 648,600 L 654,558 L 662,554 C 658,530 664,510 674,502 C 682,496 690,508 690,520 C 690,532 692,542 696,548 L 724,540 L 756,532 Z"/>
			<text class="label" x="716" y="606">Chubu</text>
		</g>
		<g class="soon" role="button" tabindex="0" data-name="Chugoku" aria-label="Chugoku — still under investigation">
			<path class="fill" d="M 509,585 L 506,636 L 436,646 L 352,648 L 286,638 L 254,616 L 264,586 L 332,566 L 422,560 Z"/>
			<text class="label" x="378" y="612">Chugoku</text>
		</g>

		<!-- ===== active regions on Honshu ===== -->
		<a class="area" href="#tokyo" aria-label="Tokyo — jump to Tokyo snacks">
			<path class="fill" d="M 790,540 L 908,520 L 921,562 L 913,602 L 928,634 L 896,650 L 876,634 L 858,656 L 821,650 L 781,634 L 776,566 Z"/>
			<text class="label" x="850" y="592"><tspan class="emoji">🗼</tspan> Tokyo</text>
		</a>
		<a class="area" href="#kyoto" aria-label="Kansai: Kyoto and Osaka — jump to Kyoto snacks">
			<path class="fill" d="M 654,558 L 648,600 L 660,662 L 632,684 L 598,712 L 560,700 L 548,672 L 524,664 L 506,636 L 509,585 L 560,568 L 610,560 Z"/>
			<text class="label two" x="580" y="612"><tspan class="emoji">⛩️</tspan> Kyoto</text>
			<text class="label two" x="580" y="642"><tspan class="emoji">🐙</tspan> Osaka</text>
		</a>

		<!-- internal region borders -->
		<path class="border" d="M 790,540 L 908,520 M 790,540 L 776,566 L 781,634 L 821,650 M 654,558 L 648,600 L 660,662 M 509,585 L 506,636"/>
		<!-- shared coastline on top -->
		<path class="coast" d="M 832,312 L 846,284 L 868,299 L 879,281 L 906,306 L 916,420 L 908,520 L 921,562 L 913,602 L 928,634 L 896,650 L 876,634 L 858,656 L 821,650 L 770,672 L 708,676 L 660,662 L 632,684 L 598,712 L 560,700 L 548,672 L 524,664 L 506,636 L 436,646 L 352,648 L 286,638 L 254,616 L 264,586 L 332,566 L 422,560 L 509,585 L 560,568 L 610,560 L 654,558 L 662,554 C 658,530 664,510 674,502 C 682,496 690,508 690,520 C 690,532 692,542 696,548 L 724,540 L 756,532 L 790,540 L 772,470 L 786,394 L 806,338 Z"/>

		<!-- ===== islands ===== -->
		<a class="area island" href="#hokkaido" aria-label="Hokkaido — jump to Hokkaido snacks">
			<path class="fill isl" d="M 814,70 L 884,96 L 964,156 L 910,196 L 928,246 L 874,264 L 824,240 L 796,276 L 764,262 L 778,212 L 756,176 L 778,126 Z"/>
			<text class="label" x="850" y="192"><tspan class="emoji">🐻</tspan> Hokkaido</text>
		</a>
		<g class="soon island" role="button" tabindex="0" data-name="Shikoku" aria-label="Shikoku — still under investigation">
			<path class="fill isl" d="M 336,684 L 424,672 L 480,684 L 472,724 L 402,744 L 336,730 Z"/>
			<text class="label" x="406" y="714">Shikoku</text>
		</g>
		<a class="area island" href="#kyushu" aria-label="Kyushu — jump to Kyushu snacks">
			<path class="fill isl" d="M 168,604 L 214,594 L 242,618 L 232,658 L 248,694 L 222,738 L 202,776 L 158,784 L 134,742 L 144,694 L 130,650 L 140,614 Z"/>
			<text class="label sm" x="196" y="696"><tspan class="emoji">🌋</tspan> Kyushu</text>
		</a>
		<a class="area island" href="#okinawa" aria-label="Okinawa — jump to Okinawa snacks">
			<rect class="hit" x="30" y="780" width="230" height="64" />
			<rect class="fill isl" x="44" y="798" width="62" height="30" rx="12"/>
			<text class="label sm side" x="116" y="820"><tspan class="emoji">🌺</tspan> Okinawa</text>
		</a>
		<!-- Sado, decorative -->
		<path class="sado" aria-hidden="true" d="M 738,466 C 734,456 742,448 752,446 C 762,444 768,452 764,462 C 760,470 748,474 742,470 C 740,469 739,468 738,466 Z"/>
	</svg>

	<figcaption class="legend">
		<span class="key active-key"><i></i> Investigated — tap to jump</span>
		<span class="key soon-key"><i></i> Still sniffing around</span>
	</figcaption>

	<!-- Inaripo's "not yet" bubble for gray regions -->
	<div class="bubble" role="status" hidden>
		<Inaripo expression="surprise" size={52} />
		<p><strong class="bubble-region">This region</strong> is still under investigation. My nose is on the case — check back soon.</p>
	</div>
</figure>

<script>
	const map = document.querySelector('.jmap');
	if (map) {
		const bubble = map.querySelector<HTMLElement>('.bubble')!;
		const regionEl = bubble.querySelector('.bubble-region')!;
		const close = () => {
			bubble.hidden = true;
		};
		map.querySelectorAll<SVGGElement>('.soon').forEach((g) => {
			const open = () => {
				regionEl.textContent = g.dataset.name ?? 'This region';
				bubble.hidden = false;
			};
			g.addEventListener('click', open);
			g.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' || e.key === ' ') {
					e.preventDefault();
					open();
				}
			});
		});
		document.addEventListener('click', (e) => {
			if (!bubble.hidden && e.target instanceof Node && !map.contains(e.target)) close();
		});
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') close();
		});
		// Jumping to a real region also dismisses the bubble.
		map.querySelectorAll('.area').forEach((a) => a.addEventListener('click', close));
	}
</script>

<style>
	.jmap {
		position: relative;
		margin: 0;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 16px;
		padding: 1.1em 1.1em 0.8em;
	}
	svg {
		display: block;
		width: 100%;
		height: auto;
	}

	/* --- landmass & coastline --- */
	.land {
		fill: #efe9dd;
	}
	.coast {
		fill: none;
		stroke: #7c5c49;
		stroke-width: 5;
		stroke-linejoin: round;
		stroke-linecap: round;
		pointer-events: none;
	}
	.border {
		fill: none;
		stroke: #7c5c49;
		stroke-width: 2;
		stroke-dasharray: 6 5;
		opacity: 0.5;
		pointer-events: none;
	}
	.sado {
		fill: #efe9dd;
		stroke: #7c5c49;
		stroke-width: 3;
		stroke-linejoin: round;
	}
	.hit {
		fill: transparent;
	}

	/* --- labels --- */
	.label {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 26px;
		font-weight: 800;
		text-anchor: middle;
		paint-order: stroke;
		stroke: #fffdf8;
		stroke-width: 5;
		stroke-linejoin: round;
		pointer-events: none;
	}
	.label.two,
	.label.sm {
		font-size: 21px;
	}
	.label.side {
		text-anchor: start;
	}
	.emoji {
		stroke: none;
	}

	/* --- active (linked) regions --- */
	.area {
		cursor: pointer;
	}
	.area .fill {
		fill: var(--accent-tint);
		stroke: var(--accent);
		stroke-width: 2.5;
		stroke-linejoin: round;
		transition: fill 0.15s ease;
	}
	.area .fill.isl {
		stroke: #7c5c49;
		stroke-width: 5;
	}
	.area .label {
		fill: var(--accent-dark);
	}
	.area:hover .fill,
	.area:focus-visible .fill {
		fill: #fbd9cb;
	}
	.area:hover,
	.area:focus-visible {
		outline: none;
	}
	.area:focus-visible .fill {
		stroke: var(--accent);
		stroke-width: 5;
	}
	@media (prefers-reduced-motion: no-preference) {
		.area.island {
			transition: transform 0.15s ease;
		}
		.area.island:hover,
		.area.island:focus-visible {
			transform: translateY(-3px);
		}
	}

	/* --- not-yet regions --- */
	.soon {
		cursor: help;
	}
	.soon .fill {
		fill: #efe9dd;
		stroke: none;
		transition: fill 0.15s ease;
	}
	.soon .fill.isl {
		stroke: #7c5c49;
		stroke-width: 5;
		stroke-linejoin: round;
	}
	.soon .label {
		fill: #948a76;
		font-size: 21px;
	}
	.soon:hover .fill,
	.soon:focus-visible .fill {
		fill: #e5dcc9;
	}
	.soon:focus-visible {
		outline: none;
	}

	/* --- legend: parked in the map's empty top-left "ocean" --- */
	.legend {
		position: absolute;
		top: 1.2em;
		left: 1.4em;
		display: flex;
		flex-direction: column;
		gap: 0.5em;
		font-size: 0.75em;
		color: rgb(var(--gray-dark));
		pointer-events: none;
	}
	.key {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
	}
	.key i {
		width: 0.95em;
		height: 0.95em;
		border-radius: 4px;
	}
	.active-key i {
		background: var(--accent-tint);
		border: 2px solid var(--accent);
	}
	.soon-key i {
		background: #efe9dd;
		border: 2px solid #7c5c49;
	}

	/* --- Inaripo bubble --- */
	.bubble[hidden] {
		display: none;
	}
	.bubble {
		display: flex;
		align-items: center;
		gap: 0.8em;
		margin-top: 0.8em;
		padding: 0.8em 1em;
		background: var(--accent-tint);
		border-radius: 12px;
		font-size: 0.85em;
		line-height: 1.5;
	}
	.bubble p {
		margin: 0;
	}
</style>
