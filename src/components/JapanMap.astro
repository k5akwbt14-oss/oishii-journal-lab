---
// Clickable Japan map for the /regional hub — v4.
// Base artwork: the operator-supplied deformed prefecture map (licensed,
// per operator 2026-07-19), recolored to the site palette with
// tools/recolor-japan-map.mjs (cell-exact, deterministic). On top sits an
// invisible SVG overlay with the labels and hit areas. Every cell links into
// the RegionExplorer below via hash (#hokkaido, #tohoku, …): pink cells are
// regions with taste-tested guides, greige cells have quick picks only.
import { Image } from 'astro:assets';
import mapImage from '../assets/illust/japan-map.webp';
---

<figure class="jmap" aria-label="Map of Japan — pick a region">
	<div class="map-wrap">
		<Image src={mapImage} alt="" widths={[640, 1074]} sizes="(max-width: 800px) 100vw, 760px" />
		<svg viewBox="0 0 1074 976" role="group" aria-label="Deformed map of Japan. Every region opens the omiyage explorer below; pink regions also have taste-tested guides.">
			<!-- greige regions first so pink hit areas win overlaps; every cell now
			     opens its block in the omiyage explorer below -->
			<a class="area soon" href="#tohoku" aria-label="Tohoku — browse Tohoku omiyage">
				<rect class="hit" x="748" y="293" width="195" height="278" />
				<text class="label" x="845" y="440">Tohoku</text>
			</a>
			<a class="area soon" href="#chubu" aria-label="Chubu — browse Chubu omiyage">
				<polygon class="hit" points="585,612 640,482 775,538 748,575 748,822 652,822 652,702 555,702 555,645" />
				<text class="label" x="690" y="645">Chubu</text>
			</a>
			<a class="area soon" href="#chugoku" aria-label="Chugoku — browse Chugoku omiyage">
				<rect class="hit" x="258" y="616" width="238" height="130" />
				<text class="label" x="380" y="690">Chugoku</text>
			</a>
			<a class="area soon" href="#shikoku" aria-label="Shikoku — browse Shikoku omiyage">
				<rect class="hit" x="225" y="752" width="245" height="153" />
				<text class="label" x="350" y="833">Shikoku</text>
			</a>

			<!-- active regions -->
			<a class="area" href="#hokkaido" aria-label="Hokkaido — jump to Hokkaido snacks">
				<rect class="hit" x="758" y="48" width="285" height="232" />
				<text class="label" x="900" y="180"><tspan class="emoji">🐻</tspan> Hokkaido</text>
			</a>
			<a class="area" href="#tokyo" aria-label="Tokyo — jump to Tokyo snacks">
				<rect class="hit" x="742" y="575" width="202" height="185" />
				<text class="label" x="840" y="660"><tspan class="emoji">🗼</tspan> Tokyo</text>
			</a>
			<!-- Kansai cell, split horizontally: top half → Kyoto, bottom half → Osaka -->
			<a class="area" href="#kyoto" aria-label="Kyoto — jump to Kyoto snacks">
				<rect class="hit" x="490" y="612" width="162" height="106" />
				<text class="label two" x="570" y="700"><tspan class="emoji">⛩️</tspan> Kyoto</text>
			</a>
			<a class="area" href="#osaka" aria-label="Osaka — jump to Osaka snacks">
				<rect class="hit" x="490" y="718" width="162" height="106" />
				<text class="label two" x="570" y="734"><tspan class="emoji">🐙</tspan> Osaka</text>
			</a>
			<a class="area" href="#kyushu" aria-label="Kyushu — jump to Kyushu snacks">
				<rect class="hit" x="88" y="655" width="140" height="255" />
				<text class="label sm" x="160" y="790"><tspan class="emoji">🌋</tspan> Kyushu</text>
			</a>
			<a class="area" href="#okinawa" aria-label="Okinawa — jump to Okinawa snacks">
				<rect class="hit" x="14" y="800" width="230" height="120" />
				<text class="label sm side" x="92" y="870"><tspan class="emoji">🌺</tspan> Okinawa</text>
			</a>
		</svg>
	</div>

	<figcaption class="legend">
		<span class="key active-key"><i></i> Taste-tested guide</span>
		<span class="key soon-key"><i></i> Quick picks below</span>
	</figcaption>
</figure>

<style>
	.jmap {
		position: relative;
		margin: 0;
		background: #fffdf8;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 16px;
		padding: 0.6em 0.6em 0.8em;
	}
	.map-wrap {
		position: relative;
	}
	.map-wrap img {
		display: block;
		width: 100%;
		height: auto;
	}
	.map-wrap svg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.hit {
		fill: transparent;
	}

	/* --- labels --- */
	.label {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 30px;
		font-weight: 800;
		text-anchor: middle;
		paint-order: stroke;
		stroke: #fffdf8;
		stroke-width: 6;
		stroke-linejoin: round;
		pointer-events: none;
	}
	.label.two,
	.label.sm {
		font-size: 24px;
	}
	.label.side {
		text-anchor: start;
	}
	.emoji {
		stroke: none;
	}

	/* --- active (linked) regions --- */
	.area {
		cursor: pointer;
	}
	.area .label {
		fill: var(--accent-dark);
		transition: fill 0.15s ease;
	}
	.area:hover .label,
	.area:focus-visible .label {
		fill: var(--accent);
		text-decoration: underline;
		text-decoration-thickness: 3px;
		text-underline-offset: 5px;
	}
	.area:hover .hit,
	.area:focus-visible .hit {
		fill: rgba(200, 65, 44, 0.06);
	}
	.area:focus-visible {
		outline: none;
	}
	.area:focus-visible .hit {
		stroke: var(--accent);
		stroke-width: 3;
		stroke-dasharray: 8 6;
	}

	/* --- quick-picks-only regions (greige cells) --- */
	.soon .label {
		fill: #948a76;
		font-size: 24px;
	}
	.soon:hover .label,
	.soon:focus-visible .label {
		fill: #6f6553;
	}
	.soon:focus-visible {
		outline: none;
	}
	.soon:focus-visible .hit {
		stroke: #948a76;
		stroke-width: 3;
		stroke-dasharray: 8 6;
	}

	/* --- legend --- */
	.legend {
		position: absolute;
		top: 1em;
		left: 1.2em;
		display: flex;
		flex-direction: column;
		gap: 0.5em;
		font-size: 0.75em;
		color: rgb(var(--gray-dark));
		pointer-events: none;
	}
	.key {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
	}
	.key i {
		width: 0.95em;
		height: 0.95em;
		border-radius: 4px;
	}
	.active-key i {
		background: #fce4d8;
		border: 2px solid var(--accent);
	}
	.soon-key i {
		background: #eae2d1;
		border: 2px solid #7c5c49;
	}
</style>
