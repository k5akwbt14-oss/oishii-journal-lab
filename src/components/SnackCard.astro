---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	image: ImageMetadata;
	imageAlt: string;
	title: string;
	tagline: string;
	facts: string[];
	whereToBuy: string;
	price: string;
	ctaText: string;
	ctaHref: string;
}

const { image, imageAlt, title, tagline, facts, whereToBuy, price, ctaText, ctaHref } = Astro.props;
---

<div class="snack-card">
	<div class="snack-image">
		<Image src={image} alt={imageAlt} width={800} height={533} />
	</div>
	<div class="snack-body">
		<h3>{title}</h3>
		<p class="tagline">{tagline}</p>
		<ul class="facts">
			{facts.map((fact) => <li>{fact}</li>)}
		</ul>
		<div class="snack-content">
			<slot />
		</div>
		<dl class="details">
			<dt>買える場所</dt>
			<dd>{whereToBuy}</dd>
			<dt>価格</dt>
			<dd>{price}</dd>
		</dl>
		<a class="cta" href={ctaHref} target="_blank" rel="sponsored noopener">{ctaText}</a>
	</div>
</div>

<style>
	.snack-card {
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		overflow: hidden;
		margin: 2em 0;
		box-shadow: var(--box-shadow);
	}
	.snack-image :global(img) {
		display: block;
		width: 100%;
		height: auto;
		margin: 0;
		border-radius: 0;
	}
	.snack-body {
		padding: 1.5em;
	}
	.snack-body h3 {
		margin-bottom: 0.25em;
	}
	.tagline {
		font-style: italic;
		color: rgb(var(--gray));
		margin-bottom: 0.75em;
	}
	.facts {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		padding: 0;
		margin: 0 0 1em 0;
	}
	.facts li {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
		border-radius: 999px;
		padding: 0.25em 0.9em;
		font-size: 0.85em;
	}
	.snack-content {
		margin-bottom: 1em;
	}
	.snack-content :global(p:last-child) {
		margin-bottom: 0;
	}
	.details {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.25em 1em;
		margin: 0 0 1.25em 0;
		font-size: 0.95em;
	}
	.details dt {
		font-weight: 600;
		color: rgb(var(--gray-dark));
	}
	.details dd {
		margin: 0;
		color: rgb(var(--gray));
	}
	.cta {
		display: inline-block;
		background: var(--accent);
		color: #fff;
		text-decoration: none;
		padding: 0.6em 1.4em;
		border-radius: 8px;
		font-weight: 600;
	}
	.cta:hover {
		background: var(--accent-dark);
		color: #fff;
	}
</style>
