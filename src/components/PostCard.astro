---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { CATEGORIES } from '../consts';

interface Props {
	post: CollectionEntry<'blog'>;
	/** Hide the category chip on pages that are already scoped to one category. */
	showCategory?: boolean;
}

const { post, showCategory = true } = Astro.props;
const category = CATEGORIES.find((c) => c.id === post.data.category);
---

<article class="card">
	<a class="cover" href={`/blog/${post.id}/`} tabindex="-1" aria-hidden="true">
		{post.data.heroImage && <Image src={post.data.heroImage} alt="" width={480} height={300} />}
	</a>
	<div class="body">
		{showCategory && category && <p class="chip">{category.title}</p>}
		<h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
		<p class="desc">{post.data.description}</p>
		<p class="date"><FormattedDate date={post.data.pubDate} /></p>
	</div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 14px;
		overflow: hidden;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}
	.card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 22px rgba(var(--gray), 28%);
	}
	.cover {
		display: block;
		aspect-ratio: 8 / 5;
		background: var(--accent-tint);
	}
	.cover :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		margin: 0;
	}
	.body {
		padding: 1em 1.1em 1.2em;
		display: flex;
		flex-direction: column;
		flex: 1;
	}
	.chip {
		align-self: flex-start;
		margin: 0 0 0.5em;
		background: var(--accent-tint);
		color: var(--accent-dark);
		font-size: 0.66em;
		font-weight: 700;
		letter-spacing: 0.06em;
		padding: 0.3em 0.7em;
		border-radius: 999px;
	}
	h3 {
		font-size: 1.05em;
		line-height: 1.35;
		margin: 0 0 0.4em;
	}
	h3 a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	h3 a:hover {
		color: var(--accent);
	}
	.desc {
		margin: 0 0 0.9em;
		font-size: 0.8em;
		line-height: 1.6;
		color: rgb(var(--gray-dark));
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.date {
		margin: auto 0 0;
		font-size: 0.72em;
		color: rgb(var(--gray));
	}
</style>
