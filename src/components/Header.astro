---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Logo from '../assets/logo.png';
---

<header>
	<nav>
		<h2>
			<a href="/" class="brand">
				<span class="brand-logo">
					<Image src={Logo} alt={`${SITE_TITLE} logo`} width={96} height={96} />
				</span>
				<span class="brand-name">{SITE_TITLE}</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Guides</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<!-- TODO: swap the "#" placeholders for your real Instagram / Pinterest URLs -->
			<a href="#" aria-label="Follow us on Instagram">
				<span class="sr-only">Follow us on Instagram</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="26" height="26" fill="none"
					><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7"
					></rect><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"></circle><circle
						cx="17.5"
						cy="6.5"
						r="1.2"
						fill="currentColor"></circle></svg
				>
			</a>
			<a href="#" aria-label="Follow us on Pinterest">
				<span class="sr-only">Follow us on Pinterest</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="26" height="26" fill="none"
					><path
						d="M12 2.5a9.5 9.5 0 0 0-3.5 18.32c-.08-.77-.15-1.96.03-2.8.16-.75 1.06-4.8 1.06-4.8s-.27-.54-.27-1.34c0-1.26.73-2.2 1.64-2.2.77 0 1.15.58 1.15 1.28 0 .78-.5 1.94-.75 3.02-.22.9.45 1.64 1.34 1.64 1.6 0 2.84-1.7 2.84-4.14 0-2.17-1.56-3.68-3.78-3.68-2.57 0-4.08 1.93-4.08 3.92 0 .78.3 1.61.67 2.06a.27.27 0 0 1 .06.26c-.07.28-.22.9-.25 1.02-.04.17-.13.2-.3.12-1.13-.52-1.83-2.17-1.83-3.5 0-2.85 2.07-5.47 5.97-5.47 3.13 0 5.57 2.23 5.57 5.22 0 3.11-1.96 5.62-4.69 5.62-.91 0-1.77-.47-2.07-1.03l-.56 2.15c-.2.78-.75 1.76-1.12 2.36A9.5 9.5 0 1 0 12 2.5Z"
						fill="currentColor"></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.6em;
		color: rgb(var(--gray-dark));
	}
	.brand-logo {
		flex-shrink: 0;
		display: block;
		width: 42px;
		height: 42px;
		border-radius: 50%;
		overflow: hidden;
		box-shadow: 0 1px 4px rgba(var(--black), 15%);
	}
	.brand-logo :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1.06);
		border-radius: 0;
	}
	.brand-name {
		font-family: var(--font-heading), serif;
		font-weight: 700;
		letter-spacing: 0.01em;
		font-size: 1.05em;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links a {
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		.brand-name {
			font-size: 0.95em;
		}
	}
</style>
