---
import { Image } from 'astro:assets';
import { CATEGORIES, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Inaripo from './Inaripo.astro';
import Logo from '../assets/logo.png';
---

<header>
	<nav>
		<h2>
			<a href="/" class="brand">
				<span class="brand-logo">
					<Image src={Logo} alt={`${SITE_TITLE} logo`} width={96} height={96} />
				</span>
				<span class="brand-name">{SITE_TITLE}</span>
			</a>
		</h2>
		<div class="internal-links">
			{CATEGORIES.map((c) => <HeaderLink href={c.href}>{c.title}</HeaderLink>)}
			<HeaderLink href="/about">サイトについて</HeaderLink>
		</div>
		<div class="nav-right">
			<a class="box-cta" href="/boxes">
				<span class="box-cta-icon" aria-hidden="true">📦</span>
				スナックBOX
			</a>
			<span class="header-mascot" title="Inaripo · いなりぽ">
				<Inaripo expression="wink" size={38} alt="Inaripo the fox" />
			</span>
			<div class="social-links">
				<a href="https://www.instagram.com/oishii.journal.lab/" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram">
					<span class="sr-only">Instagramでフォロー</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="26" height="26" fill="none"
						><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7"
						></rect><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"></circle><circle
							cx="17.5"
							cy="6.5"
							r="1.2"
							fill="currentColor"></circle></svg
					>
				</a>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.6em;
		color: rgb(var(--gray-dark));
	}
	.brand-logo {
		flex-shrink: 0;
		display: block;
		width: 42px;
		height: 42px;
		border-radius: 50%;
		overflow: hidden;
		box-shadow: 0 1px 4px rgba(var(--black), 15%);
	}
	.brand-logo :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1.06);
		border-radius: 0;
	}
	.brand-name {
		font-family: var(--font-heading), serif;
		font-weight: 700;
		letter-spacing: 0.01em;
		font-size: 1.05em;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.internal-links a {
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}
	.internal-links a:hover {
		color: var(--accent);
		border-bottom-color: var(--accent-tint);
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	/* The money page gets button weight rather than another plain nav link. */
	.box-cta {
		display: flex;
		align-items: center;
		gap: 0.4em;
		background: var(--accent);
		color: #fff;
		padding: 0.5em 1.1em;
		border-radius: 999px;
		border-bottom: 0;
		font-weight: 700;
		font-size: 0.82em;
		white-space: nowrap;
		box-shadow: 0 2px 8px rgba(200, 65, 44, 30%);
		transition:
			background 0.15s ease,
			transform 0.15s ease;
	}
	.box-cta:hover {
		background: var(--accent-dark);
		color: #fff;
		transform: translateY(-1px);
	}
	.box-cta-icon {
		font-size: 1.05em;
	}
	.header-mascot {
		display: flex;
		transition: transform 0.15s ease;
	}
	.header-mascot:hover {
		transform: translateY(-2px) rotate(-4deg);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links a {
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		.brand-name {
			font-size: 0.95em;
		}
	}
</style>
