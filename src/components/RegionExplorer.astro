---
// Prefecture-level omiyage explorer for /regional.
//
// Interaction model (Monte-Carlo-tested vs. a hover-only design, 2026-07-19):
// tap/click is the primary input everywhere; hovering a region block also
// reveals its prefecture chips on devices that actually have hover. Every
// card badge announces its destination (taste-tested article / Amazon /
// Japan-only → /boxes) so no click is a surprise, and a "US-orderable"
// filter hides the Japan-only items entirely.
//
// State lives in the URL hash (#kyoto, #tohoku, …) so the map, the home-page
// region chips, and external links can all deep-link into the explorer.
// Without JS, every prefecture row and panel renders expanded and usable.
//
// Card imagery: original illustrations in src/assets/omiyage/, one per item,
// keyed by slugify(item.name) (generated by tools/gen-omiyage-images.mjs).
// Real product photos are contractually blocked for now — Amazon images only
// via PA-API (locked until 3 sales), box creatives arrive with approval —
// so these are honest illustrations, swappable per-file later.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { OMIYAGE_BLOCKS, amazonSearchUrl } from '../data/omiyage';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/omiyage/*.webp',
	{ eager: true },
);
const slugify = (name: string) =>
	name
		.normalize('NFD')
		.replace(/[̀-ͯ]/g, '')
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-|-$/g, '');
function imageFor(name: string): ImageMetadata {
	const mod = imageModules[`../assets/omiyage/${slugify(name)}.webp`];
	if (!mod) throw new Error(`Missing omiyage illustration: ${slugify(name)}.webp (${name})`);
	return mod.default;
}

const prefCount = OMIYAGE_BLOCKS.reduce((n, b) => n + b.prefs.length, 0);
const itemCount = OMIYAGE_BLOCKS.reduce(
	(n, b) => n + b.prefs.reduce((m, p) => m + p.items.length, 0),
	0,
);

function cardMeta(item: (typeof OMIYAGE_BLOCKS)[number]['prefs'][number]['items'][number]) {
	switch (item.link.kind) {
		case 'article':
			return { href: item.link.href, cls: 'kind-article', badge: 'Taste-tested — read the file', ext: false };
		case 'amazon':
			return { href: amazonSearchUrl(item.link.q), cls: 'kind-amazon', badge: 'Find on Amazon', ext: true };
		case 'japanOnly':
			return { href: '/boxes/', cls: 'kind-japan', badge: 'Japan-only — snack boxes carry the closest', ext: false };
	}
}
---

<section class="explorer" id="explorer" aria-label="Browse omiyage by prefecture">
	<script is:inline>
		document.currentScript.parentElement.classList.add('js');
	</script>

	<header class="ex-head">
		<h2>Browse omiyage by prefecture</h2>
		<p class="sub">
			All {prefCount} prefectures, {itemCount} local gems on file. Pick a region, then a
			prefecture — every card says up front where it takes you.
		</p>
		<label class="filter">
			<input type="checkbox" id="us-filter" />
			Show only what you can order in the US
		</label>
	</header>

	<div class="blocks" role="group" aria-label="Regions of Japan">
		{
			OMIYAGE_BLOCKS.map((block) => (
				<button class="block" type="button" data-block={block.id} aria-expanded="false">
					<span class="b-tile" aria-hidden="true">{block.ja}</span>
					<span class="b-text">
						<span class="b-name">{block.name}</span>
						<span class="b-anchor">{block.anchor}</span>
					</span>
				</button>
			))
		}
	</div>

	{
		OMIYAGE_BLOCKS.map((block) => (
			<div class="prefrow" data-prefrow={block.id} role="group" aria-label={`Prefectures in ${block.name}`}>
				{block.prefs.map((pref) => (
					<button class="pref" type="button" data-pref={pref.id} data-in-block={block.id} aria-pressed="false">
						{pref.name} <span class="p-ja">{pref.ja}</span>
						<span class="p-count">{pref.items.length}</span>
					</button>
				))}
			</div>
		))
	}

	{
		OMIYAGE_BLOCKS.map((block) =>
			block.prefs.map((pref) => (
				<section class="panel" data-panel={pref.id} aria-label={`Omiyage from ${pref.name}`}>
					<h3>
						{pref.name} <span class="h-ja">{pref.ja}</span>
					</h3>
					<div class="cards">
						{pref.items.map((item) => {
							const meta = cardMeta(item);
							return (
								<a
									class={`card ${meta.cls}`}
									href={meta.href}
									target={meta.ext ? '_blank' : undefined}
									rel={meta.ext ? 'sponsored noopener' : undefined}
								>
									<span class="c-img">
										<Image src={imageFor(item.name)} alt="" widths={[240, 480]} sizes="240px" />
									</span>
									<span class="c-name">{item.name}</span>
									<span class="c-hook">{item.hook}</span>
									<span class="c-badge">{meta.badge}</span>
								</a>
							);
						})}
					</div>
					<p class="empty-note">Everything here is Japan-only so far — untick the filter to see it.</p>
				</section>
			)),
		)
	}
</section>

<script>
	const root = document.getElementById('explorer')!;
	const blocks = [...root.querySelectorAll<HTMLButtonElement>('.block')];
	const prefrows = [...root.querySelectorAll<HTMLElement>('.prefrow')];
	const prefs = [...root.querySelectorAll<HTMLButtonElement>('.pref')];
	const panels = [...root.querySelectorAll<HTMLElement>('.panel')];
	const filter = root.querySelector<HTMLInputElement>('#us-filter')!;

	let pinnedBlock = '';
	let activePref = '';

	const blockOfPref = (prefId: string) =>
		prefs.find((p) => p.dataset.pref === prefId)?.dataset.inBlock ?? '';
	const firstPrefOf = (blockId: string) =>
		prefs.find((p) => p.dataset.inBlock === blockId)?.dataset.pref ?? '';

	function showPrefrow(blockId: string) {
		prefrows.forEach((r) => r.classList.toggle('on', r.dataset.prefrow === blockId));
		blocks.forEach((b) =>
			b.setAttribute('aria-expanded', String(b.dataset.block === blockId)),
		);
	}

	function selectPref(prefId: string, { setHash = true } = {}) {
		activePref = prefId;
		pinnedBlock = blockOfPref(prefId);
		showPrefrow(pinnedBlock);
		blocks.forEach((b) => b.classList.toggle('active', b.dataset.block === pinnedBlock));
		prefs.forEach((p) => {
			const on = p.dataset.pref === prefId;
			p.classList.toggle('active', on);
			p.setAttribute('aria-pressed', String(on));
		});
		panels.forEach((pl) => pl.classList.toggle('on', pl.dataset.panel === prefId));
		if (setHash) history.replaceState(null, '', '#' + prefId);
	}

	function selectBlock(blockId: string, opts: { setHash?: boolean } = {}) {
		selectPref(firstPrefOf(blockId), { setHash: opts.setHash ?? true });
	}

	blocks.forEach((b) => {
		b.addEventListener('click', () => selectBlock(b.dataset.block!));
		// Hover preview of the prefecture chips — desktop only; tap stays primary.
		if (window.matchMedia('(hover: hover)').matches) {
			b.addEventListener('mouseenter', () => showPrefrow(b.dataset.block!));
		}
	});
	root.querySelector('.blocks')!.addEventListener('mouseleave', () => {
		if (pinnedBlock) showPrefrow(pinnedBlock);
	});
	prefs.forEach((p) => p.addEventListener('click', () => selectPref(p.dataset.pref!)));

	filter.addEventListener('change', () => {
		root.classList.toggle('filter-us', filter.checked);
	});

	// Hash deep links: region ids (from the map / home chips) and prefecture ids.
	const BLOCK_IDS = new Set(blocks.map((b) => b.dataset.block!));
	const PREF_IDS = new Set(prefs.map((p) => p.dataset.pref!));
	function applyHash(scroll: boolean) {
		const id = decodeURIComponent(location.hash.slice(1));
		if (!id) return false;
		if (PREF_IDS.has(id)) selectPref(id, { setHash: false });
		else if (BLOCK_IDS.has(id)) selectBlock(id, { setHash: false });
		else return false;
		if (scroll) root.scrollIntoView({ behavior: 'smooth', block: 'start' });
		return true;
	}
	window.addEventListener('hashchange', () => applyHash(true));
	if (!applyHash(false)) selectBlock('hokkaido', { setHash: false });
</script>

<style>
	.explorer {
		background: #fffdf8;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 16px;
		padding: 1.1em 1.2em 1.3em;
		scroll-margin-top: 4.5em;
	}

	.ex-head h2 {
		font-size: 1.35em;
		margin: 0 0 0.2em;
	}
	.ex-head .sub {
		margin: 0 0 0.6em;
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
	}
	.filter {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		font-size: 0.8em;
		font-weight: 700;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		padding: 0.35em 0.9em;
		cursor: pointer;
		user-select: none;
	}
	.filter:has(input:checked) {
		border-color: var(--accent);
		background: var(--accent-tint);
		color: var(--accent-dark);
	}
	.filter input {
		accent-color: var(--accent);
	}

	/* --- region blocks --- */
	.blocks {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 0.5em;
		margin-top: 0.9em;
	}
	.block {
		display: flex;
		align-items: center;
		gap: 0.55em;
		padding: 0.55em 0.7em;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		cursor: pointer;
		font: inherit;
		text-align: left;
		transition: border-color 0.15s ease, background 0.15s ease;
	}
	.block:hover,
	.block[aria-expanded='true'] {
		border-color: var(--accent);
		background: var(--accent-tint);
	}
	.block.active {
		border-color: var(--accent);
		box-shadow: inset 0 -3px 0 var(--accent);
	}
	.b-tile {
		flex-shrink: 0;
		display: grid;
		place-items: center;
		min-width: 2.3em;
		height: 2.3em;
		padding: 0 0.3em;
		background: var(--accent-tint);
		color: var(--accent-dark);
		border-radius: 8px;
		font-family: var(--font-heading), serif;
		font-weight: 700;
		font-size: 0.8em;
		letter-spacing: 0.05em;
	}
	.block.active .b-tile {
		background: var(--accent);
		color: #fff;
	}
	.b-text {
		display: flex;
		flex-direction: column;
		gap: 0.05em;
		min-width: 0;
	}
	.b-name {
		font-weight: 800;
		font-size: 0.85em;
	}
	.b-anchor {
		font-size: 0.66em;
		color: rgb(var(--gray));
		line-height: 1.25;
	}

	/* --- prefecture chips --- */
	.prefrow {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45em;
		margin-top: 0.8em;
		padding: 0.7em 0.8em;
		background: var(--accent-tint);
		border-radius: 12px;
	}
	.pref {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.35em 0.8em;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		cursor: pointer;
		font: inherit;
		font-size: 0.8em;
		font-weight: 700;
	}
	.pref:hover {
		border-color: var(--accent);
	}
	.pref.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}
	.pref.active .p-ja,
	.pref.active .p-count {
		color: #ffe4da;
	}
	.p-ja {
		font-weight: 400;
		color: rgb(var(--gray));
	}
	.p-count {
		font-size: 0.85em;
		color: var(--accent-dark);
		background: var(--accent-tint);
		border-radius: 999px;
		padding: 0 0.5em;
	}
	.pref.active .p-count {
		background: var(--accent-dark);
	}

	/* --- panels & cards --- */
	.panel {
		margin-top: 0.9em;
	}
	.panel h3 {
		font-size: 1.05em;
		margin: 0 0 0.55em;
	}
	.h-ja {
		font-family: var(--font-body), sans-serif;
		font-size: 0.75em;
		font-weight: 400;
		color: rgb(var(--gray));
	}
	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(215px, 1fr));
		gap: 0.7em;
	}
	.card {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
		padding: 0.55em 0.55em 0.75em;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		text-decoration: none;
		color: rgb(var(--black));
		transition: transform 0.12s ease, border-color 0.12s ease, box-shadow 0.12s ease;
	}
	.card:hover {
		transform: translateY(-2px);
		border-color: var(--accent);
		box-shadow: 0 4px 12px rgba(200, 65, 44, 0.12);
	}
	.c-img {
		display: block;
		aspect-ratio: 4 / 3;
		border-radius: 8px;
		overflow: hidden;
		background: var(--accent-tint);
		margin-bottom: 0.3em;
	}
	.c-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.18s ease;
	}
	.card:hover .c-img img {
		transform: scale(1.04);
	}
	.c-name {
		font-weight: 800;
		font-size: 0.92em;
		padding: 0 0.25em;
	}
	.c-hook {
		font-size: 0.78em;
		line-height: 1.4;
		color: rgb(var(--gray-dark));
		flex-grow: 1;
		padding: 0 0.3em;
	}
	.c-badge {
		margin-top: 0.35em;
		margin-left: 0.25em;
		font-size: 0.68em;
		font-weight: 700;
		border-radius: 999px;
		padding: 0.3em 0.7em;
		align-self: flex-start;
	}
	.kind-article .c-badge {
		background: var(--accent-tint);
		color: var(--accent-dark);
	}
	.kind-amazon .c-badge {
		background: #f2e8cf;
		color: #6d5416;
	}
	.kind-japan .c-badge {
		background: #eae2d1;
		color: #6f6553;
	}
	.kind-japan {
		border-style: dashed;
	}

	.empty-note {
		display: none;
		margin: 0.6em 0 0;
		font-size: 0.8em;
		color: rgb(var(--gray-dark));
		background: #eae2d1;
		border-radius: 10px;
		padding: 0.6em 0.9em;
	}

	/* --- filter behavior --- */
	.filter-us .card.kind-japan {
		display: none;
	}
	.filter-us .panel.on:not(:has(.card:not(.kind-japan))) .empty-note {
		display: block;
	}

	/* --- JS collapses; no-JS renders everything expanded --- */
	.js .prefrow:not(.on) {
		display: none;
	}
	.js .panel:not(.on) {
		display: none;
	}

	@media (max-width: 760px) {
		.blocks {
			grid-template-columns: repeat(2, 1fr);
		}
		.b-anchor {
			display: none;
		}
	}
</style>
