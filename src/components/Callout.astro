---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<aside class="callout">
	<p class="callout-title">{title}</p>
	<div class="callout-body">
		<slot />
	</div>
</aside>

<style>
	.callout {
		background: rgb(var(--gray-light));
		border-left: 4px solid var(--accent);
		border-radius: 8px;
		padding: 1em 1.5em;
		margin: 2em 0;
	}
	.callout-title {
		font-weight: 700;
		color: rgb(var(--black));
		margin-bottom: 0.5em;
	}
	.callout-body :global(ul) {
		margin: 0;
		padding-left: 1.25em;
	}
	.callout-body :global(p:last-child) {
		margin-bottom: 0;
	}
</style>
