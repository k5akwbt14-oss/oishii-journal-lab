---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<p class="brand-line">{SITE_TITLE}</p>
	<p class="tagline">Japanese snacks, actually eaten, honestly ranked. Only what's worth the suitcase space.</p>
	<div class="social-links">
		<a href="https://www.instagram.com/oishii.journal.lab/" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram">
			<span class="sr-only">Follow us on Instagram</span>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28" fill="none"
				><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7"
				></rect><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"></circle><circle
					cx="17.5"
					cy="6.5"
					r="1.2"
					fill="currentColor"></circle></svg
			>
		</a>
	</div>
	<p class="disclosure">
		{SITE_TITLE} is a participant in the Amazon Associates Program. As an Amazon Associate, we earn from qualifying purchases. &copy; {today.getFullYear()}
		{SITE_TITLE} All rights reserved.
	</p>
</footer>
<style>
	footer {
		padding: 2.5em 1em 5em 1em;
		background: linear-gradient(to top, var(--accent-tint), var(--cream));
		color: rgb(var(--gray));
		text-align: center;
	}
	.brand-line {
		font-family: var(--font-heading), serif;
		font-weight: 700;
		font-size: 1.25em;
		color: rgb(var(--black));
		margin: 0 0 0.25em 0;
	}
	.tagline {
		margin: 0 0 1em 0;
		font-style: italic;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-bottom: 1.25em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: var(--accent);
	}
	.disclosure {
		font-size: 0.8em;
		margin: 0;
		color: rgb(var(--gray));
	}
</style>
