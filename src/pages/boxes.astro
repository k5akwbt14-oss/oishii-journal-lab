---
import { getCollection } from 'astro:content';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Inaripo from '../components/Inaripo.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE, SNACK_BOXES } from '../consts';

const DESCRIPTION =
	'Bokksu・Sakuraco・TokyoTreat — 日本のお菓子が毎月届くスナックBOXを、実際に開けて比べました。どれがあなた向きか、ここで決まります。';

// Box reviews & comparisons live in the 特集 pillar.
const related = (await getCollection('blog', ({ data }) => data.category === 'features')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`スナックBOX | ${SITE_TITLE}`} description={DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<p class="crumb"><a href="/">ホーム</a> <span aria-hidden="true">/</span> スナックBOX</p>
				<h1>日本のお菓子が、<span class="pop">毎月届く。</span></h1>
				<p class="lead">{DESCRIPTION}</p>
			</header>

			<AffiliateDisclosure />

			{/* NOTE: every href below is a placeholder — swap in the real affiliate URLs
			    once Bokksu (Impact) / Sakuraco / TokyoTreat are approved. */}
			<section class="boxes" aria-label="スナックBOX一覧">
				{
					SNACK_BOXES.map((box) => (
						<article class="box">
							<header class="box-head">
								<span class="badge" aria-hidden="true">
									{box.badge}
								</span>
								<div>
									<h2>{box.name}</h2>
									<p class="stars" aria-label={`5点中${box.rating}点`}>
										<span aria-hidden="true">
											{'★'.repeat(box.rating)}
											<span class="star-off">{'★'.repeat(5 - box.rating)}</span>
										</span>
									</p>
								</div>
							</header>

							<p class="best-for">
								<span>こんな人に</span>
								{box.bestFor}
							</p>
							<p class="blurb">{box.blurb}</p>

							<ul class="points">
								{box.points.map((p) => (
									<li>{p}</li>
								))}
							</ul>

							<p class="catch">
								<span aria-hidden="true">⚠️</span>
								{box.catch}
							</p>

							<footer class="box-foot">
								<p class="offer">{box.offer}</p>
								<a class="visit" href={box.href} rel="sponsored noopener" target="_blank">
									{box.name}を見る <span aria-hidden="true">→</span>
								</a>
							</footer>
						</article>
					))
				}
			</section>

			<p class="note">
				<Inaripo expression="happy" size={56} />
				<span>
					値段や個数は各社でよく変わるから、ここでは書かないでおくね。最新の金額は公式サイトで確かめて！
				</span>
			</p>

			{
				related.length > 0 && (
					<section class="related" aria-labelledby="related-heading">
						<h2 id="related-heading">じっくり読みたい人へ</h2>
						<div class="related-grid">
							{related.map((post) => (
								<PostCard post={post} showCategory={false} />
							))}
						</div>
					</section>
				)
			}
		</main>
		<Footer />

		<style>
			main {
				width: 1120px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 0 3em;
			}
			.page-head {
				text-align: center;
				margin-bottom: 0.5em;
			}
			.crumb {
				font-size: 0.75em;
				color: rgb(var(--gray));
				margin: 0 0 0.6em;
			}
			.crumb a {
				text-decoration: none;
			}
			.crumb a:hover {
				text-decoration: underline;
			}
			h1 {
				font-size: 2.6em;
				margin: 0 0 0.3em;
			}
			h1 .pop {
				color: var(--accent);
			}
			.lead {
				margin: 0 auto;
				max-width: 44em;
				font-size: 0.92em;
				color: rgb(var(--gray-dark));
			}

			.boxes {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.2em;
				margin-bottom: 1.5em;
			}
			.box {
				display: flex;
				flex-direction: column;
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 16px;
				padding: 1.4em;
			}
			.box-head {
				display: flex;
				align-items: center;
				gap: 0.75em;
				margin-bottom: 0.9em;
			}
			.badge {
				flex: none;
				width: 54px;
				height: 54px;
				display: grid;
				place-items: center;
				border-radius: 12px;
				background: var(--accent-tint);
				color: var(--accent-dark);
				font-family: var(--font-heading), serif;
				font-size: 1.6em;
				font-weight: 700;
				line-height: 1;
			}
			.box h2 {
				font-size: 1.3em;
				margin: 0 0 0.15em;
			}
			.stars {
				margin: 0;
				font-size: 0.85em;
				color: var(--accent-bright);
				line-height: 1;
			}
			.star-off {
				color: rgb(var(--gray-light));
			}
			.best-for {
				display: flex;
				align-items: center;
				gap: 0.5em;
				margin: 0 0 0.7em;
				font-size: 0.82em;
				font-weight: 700;
				color: var(--accent-dark);
			}
			.best-for span {
				background: var(--accent);
				color: #fff;
				font-size: 0.78em;
				padding: 0.2em 0.6em;
				border-radius: 999px;
			}
			.blurb {
				margin: 0 0 0.8em;
				font-size: 0.84em;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
			}
			.points {
				margin: 0 0 0.9em;
				padding: 0;
				list-style: none;
				display: grid;
				gap: 0.4em;
			}
			.points li {
				position: relative;
				padding-left: 1.3em;
				font-size: 0.8em;
				line-height: 1.6;
			}
			.points li::before {
				content: '✓';
				position: absolute;
				left: 0;
				color: var(--accent);
				font-weight: 700;
			}
			.catch {
				display: flex;
				gap: 0.5em;
				margin: 0 0 1.2em;
				padding: 0.7em 0.8em;
				background: var(--cream);
				border-radius: 8px;
				font-size: 0.76em;
				line-height: 1.6;
				color: rgb(var(--gray-dark));
			}
			.box-foot {
				margin-top: auto;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.6em;
				flex-wrap: wrap;
			}
			.offer {
				margin: 0;
				font-size: 0.82em;
				font-weight: 700;
				color: var(--accent-dark);
			}
			.visit {
				background: var(--accent);
				color: #fff;
				text-decoration: none;
				font-size: 0.8em;
				font-weight: 700;
				padding: 0.6em 1.1em;
				border-radius: 999px;
				white-space: nowrap;
			}
			.visit:hover {
				background: var(--accent-dark);
				color: #fff;
			}

			.note {
				display: flex;
				align-items: center;
				gap: 0.9em;
				background: var(--accent-tint);
				border-radius: 14px;
				padding: 1em 1.3em;
				margin: 0 0 2.5em;
				font-size: 0.85em;
				line-height: 1.6;
			}

			.related h2 {
				font-size: 1.5em;
				margin: 0 0 0.8em;
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.1em;
			}

			@media (max-width: 900px) {
				.boxes,
				.related-grid {
					grid-template-columns: 1fr 1fr;
				}
			}
			@media (max-width: 640px) {
				h1 {
					font-size: 1.9em;
				}
				.boxes,
				.related-grid {
					grid-template-columns: 1fr;
				}
				.note {
					flex-direction: column;
					text-align: center;
				}
			}
		</style>
	</body>
</html>
