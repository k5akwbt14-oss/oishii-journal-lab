---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import Logo from '../assets/logo.png';
import InaripoPortrait from '../assets/inaripo/inaripo-portrait.png';

const description =
	"OISHII JOURNAL LAB. taste-tests Japan's best snacks and souvenir sweets and ranks them honestly — so you can't go wrong.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				padding: 0;
			}
			.wrap {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
			}

			/* ---- Hero ---- */
			.hero {
				text-align: center;
				padding: 3.5em 0 1em;
			}
			.hero-logo {
				width: 160px;
				height: 160px;
				margin: 0 auto 1.25em;
				border-radius: 50%;
				overflow: hidden;
				box-shadow: var(--box-shadow);
			}
			.hero-logo :global(img) {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				transform: scale(1.05);
				border-radius: 0;
				margin: 0;
			}
			.hero h1 {
				font-size: 3em;
				line-height: 1.05;
				margin-bottom: 0.35em;
			}
			.hero .lede {
				font-size: 1.25em;
				color: rgb(var(--gray-dark));
				max-width: 30ch;
				margin: 0 auto;
			}
			.hero .pop {
				color: var(--accent);
			}

			/* ---- Story ---- */
			.story {
				padding: 2.5em 0 0.5em;
			}
			.story p {
				font-size: 1.08em;
			}

			/* ---- What you'll find ---- */
			.grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1em;
				margin: 2.5em 0;
			}
			.card {
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				padding: 1.4em;
			}
			.card .tile {
				width: 2em;
				height: 2em;
				display: grid;
				place-items: center;
				border-radius: 10px;
				background: var(--accent-tint);
				color: var(--accent-dark);
				font-family: var(--font-heading), serif;
				font-size: 1.3em;
				font-weight: 700;
				line-height: 1;
				margin-bottom: 0.45em;
			}
			.card h3 {
				font-size: 1.12em;
				margin-bottom: 0.25em;
			}
			.card p {
				margin: 0;
				font-size: 0.95em;
				color: rgb(var(--gray-dark));
			}

			/* ---- Promise / how we pick ---- */
			.promise {
				background: var(--accent-tint);
				border-radius: 18px;
				padding: 2em 2.25em;
				margin: 2.5em 0;
			}
			.promise h2 {
				font-size: 1.5em;
				margin-bottom: 0.75em;
			}
			.promise ul {
				margin: 0;
				padding-left: 1.2em;
			}
			.promise li {
				margin-bottom: 0.5em;
			}
			.promise li:last-child {
				margin-bottom: 0;
			}
			.promise b {
				color: rgb(var(--black));
			}

			/* ---- Meet Inaripo ---- */
			.mascot {
				display: grid;
				grid-template-columns: 300px 1fr;
				gap: 2em;
				align-items: center;
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 20px;
				overflow: hidden;
				box-shadow: var(--box-shadow);
				margin: 2.5em 0;
			}
			.mascot-photo {
				position: relative;
				align-self: stretch;
				min-height: 260px;
				background: linear-gradient(160deg, var(--accent-tint), #fff);
			}
			.mascot-photo :global(img) {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: 60% 50%;
				border-radius: 0;
				margin: 0;
			}
			.mascot-body {
				padding: 2em 2em 2em 0;
			}
			.mascot-body .kicker {
				text-transform: uppercase;
				letter-spacing: 0.12em;
				font-size: 0.78em;
				font-weight: 700;
				color: var(--accent);
				margin-bottom: 0.3em;
			}
			.mascot-body h2 {
				font-size: 1.7em;
				margin-bottom: 0.5em;
			}
			.mascot-body .name-jp {
				font-size: 0.6em;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.mascot-body p {
				font-size: 1em;
			}
			.mascot-body .jp {
				color: rgb(var(--gray-dark));
				font-size: 0.95em;
				border-top: 1px dashed rgb(var(--gray-light));
				padding-top: 1em;
				margin-top: 1em;
			}

			/* ---- CTA ---- */
			.cta-block {
				text-align: center;
				padding: 1em 0 4em;
			}
			.cta-block h2 {
				font-size: 1.6em;
				margin-bottom: 0.75em;
			}
			.btn {
				display: inline-block;
				text-decoration: none;
				padding: 0.75em 1.7em;
				border-radius: 999px;
				font-weight: 700;
				font-size: 1.05em;
				background: var(--accent);
				color: #fff;
			}
			.btn:hover {
				background: var(--accent-dark);
				color: #fff;
			}

			.disclosure {
				font-size: 0.85em;
				color: rgb(var(--gray));
				text-align: center;
				padding-bottom: 3em;
			}

			@media (max-width: 720px) {
				.hero {
					padding: 2em 0 0.5em;
				}
				.hero h1 {
					font-size: 2.2em;
				}
				.hero-logo {
					width: 128px;
					height: 128px;
				}
				.grid {
					grid-template-columns: 1fr;
				}
				.promise {
					padding: 1.5em 1.5em;
				}
				.mascot {
					grid-template-columns: 1fr;
				}
				.mascot-photo {
					min-height: 220px;
				}
				.mascot-photo :global(img) {
					object-position: 60% 35%;
				}
				.mascot-body {
					padding: 0 1.5em 1.75em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero wrap">
				<div class="hero-logo">
					<Image src={Logo} alt={`${SITE_TITLE} logo`} width={320} height={320} />
				</div>
				<h1>We eat our way through Japan's snacks — <span class="pop">so you never have to guess.</span></h1>
				<p class="lede">Which Japanese snacks are actually worth buying?</p>
			</section>

			<section class="story wrap">
				<p>
					You're standing in front of a wall of 200 snacks and your train leaves in ten minutes — no time to gamble. <b>OISHII JOURNAL LAB.</b>
					actually eats Japan's snacks and souvenir sweets, then tells you plainly which ones are a buy and which ones you can skip.
				</p>
			</section>

			<section class="wrap">
				<div class="grid">
					<div class="card">
						<span class="tile" aria-hidden="true">菓</span>
						<h3>Souvenir Sweets</h3>
						<p>Gifts you can't go wrong with — and the pretty boxes that are only pretty boxes.</p>
					</div>
					<div class="card">
						<span class="tile" aria-hidden="true">店</span>
						<h3>Convenience-Store Gems</h3>
						<p>The snacks locals buy on repeat.</p>
					</div>
					<div class="card">
						<span class="tile" aria-hidden="true">評</span>
						<h3>No-Nonsense Rankings</h3>
						<p>Taste, price, where to buy — decide in seconds.</p>
					</div>
				</div>
			</section>

			<section class="wrap">
				<div class="promise">
					<h2>How we pick</h2>
					<ul>
						<li><b>We eat first.</b> If we wouldn't carry it home ourselves, it doesn't get listed.</li>
						<li><b>Specifics.</b> Price, where to buy, how well it travels.</li>
						<li><b>No filler.</b> Short, honest, fast to read.</li>
					</ul>
				</div>
			</section>

			<section class="wrap">
				<div class="mascot">
					<div class="mascot-photo">
						<Image src={InaripoPortrait} alt="Inaripo, a plump little fox with cheeks stuffed with a rice ball" width={900} height={780} />
					</div>
					<div class="mascot-body">
						<p class="kicker">Meet your guide</p>
						<h2>Inaripo <span class="name-jp">いなりぽ</span></h2>
						<p>
							A <b>permanently hungry</b> little fox. The name comes from Inari — Japan's fox shrines of the rice harvest — and his favorite food, <i>inarizushi</i> (sweet tofu-wrapped sushi).
							When his tail starts wagging, something is seriously good. When it's just okay, he'll say so — mouth still full.
						</p>
					</div>
				</div>
			</section>

			<section class="cta-block wrap">
				<h2>Hungry yet?</h2>
				<a class="btn" href="/blog">Browse the guides</a>
			</section>

			<p class="disclosure wrap">
				Some links on this site are affiliate links. As an Amazon Associate, we earn from qualifying purchases — at no extra cost to you.
			</p>
		</main>
		<Footer />
	</body>
</html>
