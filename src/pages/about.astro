---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import Logo from '../assets/logo.png';
import InaripoPortrait from '../assets/inaripo/inaripo-portrait.png';

const description =
	'OISHII JOURNAL LAB. は、日本の名品お菓子・お土産スイーツを実際に食べて正直にランキングする、失敗しないためのガイドです。';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`サイトについて · ${SITE_TITLE}`} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				padding: 0;
			}
			.wrap {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
			}

			/* ---- Hero ---- */
			.hero {
				text-align: center;
				padding: 3.5em 0 1em;
			}
			.hero-logo {
				width: 160px;
				height: 160px;
				margin: 0 auto 1.25em;
				border-radius: 50%;
				overflow: hidden;
				box-shadow: var(--box-shadow);
			}
			.hero-logo :global(img) {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				transform: scale(1.05);
				border-radius: 0;
				margin: 0;
			}
			.hero h1 {
				font-size: 3em;
				line-height: 1.05;
				margin-bottom: 0.35em;
			}
			.hero .lede {
				font-size: 1.25em;
				color: rgb(var(--gray-dark));
				max-width: 30ch;
				margin: 0 auto;
			}
			.hero .pop {
				color: var(--accent);
			}

			/* ---- Story ---- */
			.story {
				padding: 2.5em 0 0.5em;
			}
			.story p {
				font-size: 1.08em;
			}

			/* ---- What you'll find ---- */
			.grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1em;
				margin: 2.5em 0;
			}
			.card {
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				padding: 1.4em;
			}
			.card .emoji {
				font-size: 1.8em;
				display: block;
				margin-bottom: 0.35em;
			}
			.card h3 {
				font-size: 1.12em;
				margin-bottom: 0.25em;
			}
			.card p {
				margin: 0;
				font-size: 0.95em;
				color: rgb(var(--gray-dark));
			}

			/* ---- Promise / how we pick ---- */
			.promise {
				background: var(--accent-tint);
				border-radius: 18px;
				padding: 2em 2.25em;
				margin: 2.5em 0;
			}
			.promise h2 {
				font-size: 1.5em;
				margin-bottom: 0.75em;
			}
			.promise ul {
				margin: 0;
				padding-left: 1.2em;
			}
			.promise li {
				margin-bottom: 0.5em;
			}
			.promise li:last-child {
				margin-bottom: 0;
			}
			.promise b {
				color: rgb(var(--black));
			}

			/* ---- Meet Inaripo ---- */
			.mascot {
				display: grid;
				grid-template-columns: 300px 1fr;
				gap: 2em;
				align-items: center;
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 20px;
				overflow: hidden;
				box-shadow: var(--box-shadow);
				margin: 2.5em 0;
			}
			.mascot-photo {
				position: relative;
				align-self: stretch;
				min-height: 260px;
				background: linear-gradient(160deg, var(--accent-tint), #fff);
			}
			.mascot-photo :global(img) {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: 60% 50%;
				border-radius: 0;
				margin: 0;
			}
			.mascot-body {
				padding: 2em 2em 2em 0;
			}
			.mascot-body .kicker {
				text-transform: uppercase;
				letter-spacing: 0.12em;
				font-size: 0.78em;
				font-weight: 700;
				color: var(--accent);
				margin-bottom: 0.3em;
			}
			.mascot-body h2 {
				font-size: 1.7em;
				margin-bottom: 0.5em;
			}
			.mascot-body .name-jp {
				font-size: 0.6em;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.mascot-body p {
				font-size: 1em;
			}
			.mascot-body .jp {
				color: rgb(var(--gray-dark));
				font-size: 0.95em;
				border-top: 1px dashed rgb(var(--gray-light));
				padding-top: 1em;
				margin-top: 1em;
			}

			/* ---- CTA ---- */
			.cta-block {
				text-align: center;
				padding: 1em 0 4em;
			}
			.cta-block h2 {
				font-size: 1.6em;
				margin-bottom: 0.75em;
			}
			.btn {
				display: inline-block;
				text-decoration: none;
				padding: 0.75em 1.7em;
				border-radius: 999px;
				font-weight: 700;
				font-size: 1.05em;
				background: var(--accent);
				color: #fff;
			}
			.btn:hover {
				background: var(--accent-dark);
				color: #fff;
			}

			.disclosure {
				font-size: 0.85em;
				color: rgb(var(--gray));
				text-align: center;
				padding-bottom: 3em;
			}

			@media (max-width: 720px) {
				.hero {
					padding: 2em 0 0.5em;
				}
				.hero h1 {
					font-size: 2.2em;
				}
				.hero-logo {
					width: 128px;
					height: 128px;
				}
				.grid {
					grid-template-columns: 1fr;
				}
				.promise {
					padding: 1.5em 1.5em;
				}
				.mascot {
					grid-template-columns: 1fr;
				}
				.mascot-photo {
					min-height: 220px;
				}
				.mascot-photo :global(img) {
					object-position: 60% 35%;
				}
				.mascot-body {
					padding: 0 1.5em 1.75em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero wrap">
				<div class="hero-logo">
					<Image src={Logo} alt={`${SITE_TITLE} logo`} width={320} height={320} />
				</div>
				<h1>日本のお菓子を食べ尽くして、<span class="pop">迷わない選び方をお届け。</span></h1>
				<p class="lede">どの日本のお菓子が、本当に買う価値があるのか。</p>
			</section>

			<section class="story wrap">
				<p>
					200種類のお菓子が並ぶ棚を前に、電車の時間も迫っている——そんなときに賭けをしている余裕はありません。<b>OISHII JOURNAL LAB.</b>
					は、日本のお菓子とお土産スイーツを実際に食べて、どれが「買い」でどれは見送っていいかを、はっきりお伝えします。
				</p>
			</section>

			<section class="wrap">
				<div class="grid">
					<div class="card">
						<span class="emoji">🍡</span>
						<h3>お土産スイーツ</h3>
						<p>間違いなしのおみやげと、見た目だけのものを正直に。</p>
					</div>
					<div class="card">
						<span class="emoji">🏪</span>
						<h3>コンビニの逸品</h3>
						<p>地元の人がリピートするコンビニお菓子。</p>
					</div>
					<div class="card">
						<span class="emoji">📊</span>
						<h3>わかりやすいランキング</h3>
						<p>味・価格・買える場所まで、数秒で決められる。</p>
					</div>
				</div>
			</section>

			<section class="wrap">
				<div class="promise">
					<h2>選び方のルール</h2>
					<ul>
						<li><b>まず実食。</b> 自分たちが持ち帰りたくないものは載せません。</li>
						<li><b>具体的な情報。</b> 価格、買える場所、持ち運びやすさ。</li>
						<li><b>ムダなし。</b> 短く、正直に、サッと読める。</li>
					</ul>
				</div>
			</section>

			<section class="wrap">
				<div class="mascot">
					<div class="mascot-photo">
						<Image src={InaripoPortrait} alt="おにぎりを頬張る、ふっくらした子ぎつね・いなりぽ" width={900} height={780} />
					</div>
					<div class="mascot-body">
						<p class="kicker">ガイド役の紹介</p>
						<h2>いなりぽ</h2>
						<p>
							とても<b>食いしん坊</b>な子ぎつね。名前は、お稲荷さん（お米の神社の狐）と、大好物の<i>いなり寿司</i>から。
							しっぽがふりふり揺れたら「本気でおいしい」の合図。イマイチなときも、口いっぱいのまま正直にお伝えします。
						</p>
					</div>
				</div>
			</section>

			<section class="cta-block wrap">
				<h2>お腹すいてきた？</h2>
				<a class="btn" href="/blog">ガイドを見てみる</a>
			</section>

			<p class="disclosure wrap">
				一部のリンクはアフィリエイトリンクです。当サイトはAmazonアソシエイトとして、あなたの負担を増やすことなく、適格販売により収益を得ています。
			</p>
		</main>
		<Footer />
	</body>
</html>
